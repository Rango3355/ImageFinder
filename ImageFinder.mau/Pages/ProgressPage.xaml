<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ImageFinder.mau.Pages.ProgressPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout 
        Padding="20" 
        Spacing="12">

        <Label
			x:Name="lblProgressImages"
            Text="Processing images..."
            FontSize="18"
            HorizontalOptions="Center" />

        <ProgressBar
			x:Name="pbImageProgressBar"
            Progress="{Binding Progress}"
            HeightRequest="8" />

        <Label
			x:Name="lblProgress"
            Text="{Binding Progress, StringFormat='Progress: {0:P0}'}"
            HorizontalOptions="Center" />

        <HorizontalStackLayout
            Padding="20" 
            Spacing="12"
            HorizontalOptions="Center">
            <Button
			    x:Name="btnStartProcess"
                Text="Start"
                Command="{Binding StartProcessingCommand}" />

            <Button
			    x:Name="btnStartOver"
                Text="Start Over"
			    SemanticProperties.Hint="Return to start page"
			    Clicked="OnStartOver_Clicked" />
        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>
