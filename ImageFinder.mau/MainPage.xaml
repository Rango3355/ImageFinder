<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ImageFinder.mau.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">

            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                <Label
                    Text="ImageFinder"
                    FontSize="26"
                    FontAttributes="Bold" />

                <Label
                    Text="Organise your photos into Year / Month folders"
                    FontSize="14"
                    Opacity="0.7"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Image
                Source="dotnet_bot.png"
                HeightRequest="150"
                Aspect="AspectFit"
                HorizontalOptions="Center" />

            <Border
                Stroke="{DynamicResource Gray500}"
                StrokeThickness="1"
                BackgroundColor="{DynamicResource SecondaryContainer}"
                Padding="16"
                StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="10">

                    <Label
                        Text="Step 1 • Select source folder"
                        FontAttributes="Bold"
                        FontSize="16" />

                    <Button
                        x:Name="btnGetSourcePath"
                        Text="Choose source folder"
                        SemanticProperties.Hint="Allows to choose source folder"
                        Clicked="OnSourcePath_Clicked"
                        HorizontalOptions="Start" />

                    <Label
                        x:Name="lblSourcePath"
                        Text=""
                        Style="{StaticResource SubHeadline}"
                        IsVisible="False"
                        LineBreakMode="TailTruncation" />
                </VerticalStackLayout>
            </Border>

            <Border
                Stroke="{DynamicResource Gray500}"
                StrokeThickness="1"
                BackgroundColor="{DynamicResource SecondaryContainer}"
                Padding="16"
                StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="10">

                    <Label
                        Text="Step 2 • Select destination folder"
                        FontAttributes="Bold"
                        FontSize="16" />

                    <Button
                        x:Name="btnGetDestinationPath"
                        Text="Choose destination folder"
                        SemanticProperties.Hint="Allows to choose destination folder"
                        Clicked="OnDestinationPath_Clicked"
                        HorizontalOptions="Start"
                        IsVisible="False" />

                    <Label
                        x:Name="lblDestinationPath"
                        Text=""
                        Style="{StaticResource SubHeadline}"
                        IsVisible="False"
                        LineBreakMode="TailTruncation" />
                </VerticalStackLayout>
            </Border>

            <Button
                x:Name="btnStartProcess"
                Text="Process images"
                SemanticProperties.Hint="Starts the image finding process"
                Clicked="OnProcessImages_Clicked"
                IsVisible="False"
                HorizontalOptions="Center"
                Margin="0,12,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>